{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "<INSIRA_SUA_API_KEY_DO_UPSTASH_AQUI>"
            ]
        },
        "shadcn": {
            "command": "npx",
