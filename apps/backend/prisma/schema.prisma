generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  pets         Pet[]
  appointments Appointment[]
}

model Pet {
  id           String        @id @default(uuid())
  name         String
  breed        String
  age          Int
  userId       String
  owner        User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  category    String   // FOOD, ACCESSORY
  stock       Int
}

model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  type      String   // BATH, GROOMING, CONSULTATION
  status    String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  petId     String
  pet       Pet      @relation(fields: [petId], references: [id])
}

model Breed {
  id          String @id @default(uuid())
  name        String @unique
  description String
  image       String
}
