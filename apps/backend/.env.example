# ──────────────────────────────────────────────
# Petshop Small Breeds Premium — Backend
# Copy this file as .env and fill in real values
# ──────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# PostgreSQL local default
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/petshop?schema=public"

# Auth — CHANGE THIS in production!
JWT_SECRET="change-me-to-a-strong-random-secret"
AUTH_COOKIE_NAME="petshop_session"
AUTH_COOKIE_DOMAIN=""
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_MAX_AGE_MS="86400000"

# Demo seed is allowed only when explicitly enabled in local development.
ALLOW_DEMO_SEED="false"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:5173"
