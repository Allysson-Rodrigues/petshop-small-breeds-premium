# Global Git Ignore Patterns
# ---------------------------

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/
.docusaurus/

# Environment variables
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Temporary files
tmp/
coverage/
.eslintcache
.stylelintcache
.npm
.cache
.parcel-cache
.turbo

# Local-only folders (keep out of repo)
apps/frontend/design-system/
docs/

# Local-only database (SQLite)
apps/backend/prisma/dev.db
