# Global Git Ignore Patterns
# ---------------------------

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
build/
.next/
out/
.docusaurus/

# Environment variables
.env
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# Temporary files
tmp/
coverage/
.eslintcache
.stylelintcache
.npm
.cache
.parcel-cache
.turbo

# Local-only folders (keep out of repo)
apps/frontend/design-system/
docs/

# Local-only database (SQLite)
apps/backend/prisma/dev.db
apps/backend/dev.db

# Local-only seed with hardcoded credentials (dev-only)
apps/backend/seed_admin.ts

# Local-only helper scripts
apps/frontend/download_img.py
apps/frontend/download_cushion.py

# Local-only workspace tooling
apps/frontend/.agent/

# Local-only one-off scripts
apps/frontend/get_image.mjs
apps/frontend/full-audit-resolution.md

# Local-only template notes
apps/backend/COMMANDS.md
apps/backend/branch.txt

# Common local artifacts (prevent accidental commits)
.vercel/
playwright-report/
test-results/
__pycache__/
*.pyc
*.pid
apps/frontend/.npmrc

# Monorepo: keep a single lockfile at repo root
apps/*/package-lock.json
.vercel
